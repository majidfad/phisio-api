# Server secrets + GHCR image refs for /opt/phisio/.env
# CI fills PHISIO_*_IMAGE on each deploy (immutable commit SHA tags).

COMPOSE_PROJECT_NAME=phisio

POSTGRES_DB=phisio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

JWT_SECRET_KEY=change-me-use-a-secret-key-at-least-32-characters-long
JWT_ISSUER=Phisio.Api
JWT_AUDIENCE=Phisio.Client
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60

# Required GHCR refs (set by GitHub Actions — do not use *:local).
# Example:
#   PHISIO_API_IMAGE=ghcr.io/<owner>/phisio-api:<git-sha>
#   PHISIO_WEB_IMAGE=ghcr.io/<owner>/phisio-web:<git-sha>
PHISIO_API_IMAGE=
PHISIO_WEB_IMAGE=

# Public HTTP port for nginx (web profile).
HTTP_PORT=3000

# Postgres host port (localhost only). Container stays on 5432.
POSTGRES_PORT=5432
