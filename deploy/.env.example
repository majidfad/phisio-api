# Copy to /opt/phisio/.env on the server.

POSTGRES_DB=phisio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

JWT_SECRET_KEY=change-me-use-a-secret-key-at-least-32-characters-long
JWT_ISSUER=Phisio.Api
JWT_AUDIENCE=Phisio.Client
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60

# Set by API / Web GitHub Actions deploys (do not hardcode secrets here).
PHISIO_API_IMAGE=phisio-api:local
PHISIO_WEB_IMAGE=phisio-web:pending

# Host port published by nginx (web). Maps to container port 80.
HTTP_PORT=3000
